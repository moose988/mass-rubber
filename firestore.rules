rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function role() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function engineer() { return signedIn() && (role() == 'engineer' || role() == 'administrator'); }
    match /recipes/{id} { allow read: if signedIn() && resource.data.approved == true; allow create, update, delete: if engineer(); }
    match /unit_records/{id} { allow read, create: if signedIn() && request.resource.data.scopeId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.scopes; allow update, delete: if engineer(); }
    match /audit_log/{id} { allow read: if engineer(); allow create: if signedIn(); allow update, delete: if false; }
    match /users/{id} { allow read: if signedIn() && request.auth.uid == id; allow write: if false; }
    match /{document=**} { allow read, write: if false; }
  }
}
